+          if (!res.ok) throw new Error("config");
+          config = await res.json();
+          window.__vystiRuntimeConfig = config;
+        } catch (err) {
+          logDecision("classic", "config-failed");
+          return;
+        }
+
+        const rollout = (config && config.rollout && config.rollout.studentReact) || {};
+
+        if (rollout.killSwitch) {
+          logDecision("classic", "killswitch");
+          return;
+        }
+
+        const user = session.user || {};
+        const email = String(user.email || "").toLowerCase();
+        const userId = user.id || "";
+        const denyEmails = (rollout.denyEmails || []).map((item) =>
+          String(item || "").toLowerCase()
+        );
+
+        if (email && denyEmails.includes(email)) {
+          logDecision("classic", "denied");
+          return;
+        }
+
+        const allowEmails = (rollout.allowEmails || []).map((item) =>
+          String(item || "").toLowerCase()
+        );
+        const allowUserIds = rollout.allowUserIds || [];
+        const enabled = Boolean(rollout.enabled);
+        const percentage = Number(rollout.percentage || 0);
+
+        let eligible = false;
+        let reason = "bucket";
+        let bucket = null;
+
+        if (forceReact) {
+          eligible = true;
+          reason = "override-react";
+        } else if (email && allowEmails.includes(email)) {
+          eligible = true;
+          reason = "allowlist";
+        } else if (userId && allowUserIds.includes(userId)) {
+          eligible = true;
+          reason = "allowlist";
+        } else if (!enabled || percentage <= 0) {
+          logDecision("classic", "rollout-disabled");
+          return;
+        } else {
+          const hashSource = userId || email;
+          if (!hashSource) {
+            logDecision("classic", "no-identifier");
+            return;
+          }
