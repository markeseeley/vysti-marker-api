+        const parts = [`decision=${decision}`, `reason=${reason}`];
+        if (details.user) parts.push(`user=${details.user}`);
+        if (typeof details.bucket === "number") parts.push(`bucket=${details.bucket}`);
+        if (typeof details.percentage === "number") parts.push(`percentage=${details.percentage}`);
+        console.log(`[rollout] ${parts.join(" ")}`);
+      };
+
+      const buildTargetUrl = () => {
+        const nextParams = new URLSearchParams(params);
+        nextParams.delete("classic");
+        nextParams.delete("react");
+        const query = nextParams.toString();
+        return `/student_react.html${query ? `?${query}` : ""}`;
+      };
+
+      const checkHealthcheck = async (enabled) => {
+        if (!enabled) return true;
+        try {
+          const head = await fetch("/assets/student-react/main.js", {
+            method: "HEAD",
+            cache: "no-store"
+          });
+          if (head.ok) return true;
+        } catch (err) {}
+        try {
+          const get = await fetch("/assets/student-react/main.js", { cache: "no-store" });
+          return get.ok;
+        } catch (err) {
+          return false;
+        }
+      };
+
+      const hashToBucket = async (value) => {
+        if (window.crypto?.subtle && window.TextEncoder) {
+          try {
+            const data = new TextEncoder().encode(value);
+            const digest = await window.crypto.subtle.digest("SHA-256", data);
+            const bytes = new Uint8Array(digest);
+            const prefix = (bytes[0] << 8) | bytes[1];
+            return prefix % 100;
+          } catch (err) {}
+        }
+        let hash = 2166136261;
+        for (let i = 0; i < value.length; i += 1) {
+          hash ^= value.charCodeAt(i);
+          hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
+        }
+        return Math.abs(hash) % 100;
+      };
+
+      const rolloutState = { ran: false };
+
+      const maybeRedirect = async (session) => {
+        if (rolloutState.ran) return;
+        rolloutState.ran = true;
+
+        if (!session) {
+          logDecision("classic", "no-session");
+          return;
+        }
+
+        if (forceClassic) {
+          logDecision("classic", "override-classic");
+          return;
+        }
+
+        let config;
+        try {
