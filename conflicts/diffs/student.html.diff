+    // EARLY GLOBAL DRAG/DROP GUARD
+    // Prevent the browser from navigating/opening/downloading a file when one is dropped anywhere on the page.
+    // Must be robust across browsers (Chrome/Edge/Safari/Firefox) and must NOT block the dropZone handler.
+    (function () {
+      const opts = { capture: true, passive: false };
+
+      function isFileDrag(e) {
+        const dt = e && e.dataTransfer;
+        if (!dt) return false;
+
+        // Best signal: DataTransferItem.kind === "file"
+        if (dt.items && dt.items.length) {
+          for (const item of dt.items) {
+            if (item && item.kind === "file") return true;
+          }
+        }
+
+        // Drop often has files populated
+        if (dt.files && dt.files.length) return true;
+
+        // Cross-browser type hints
+        const types = dt.types ? Array.from(dt.types) : [];
+        return (
+          types.includes("Files") ||                   // Chromium/Edge
+          types.includes("application/x-moz-file") ||  // Firefox
+          types.includes("public.file-url")            // Safari
+        );
+      }
+
+      function preventFileNav(e) {
+        if (!e) return;
+
+        // Always block the browser's default "open/download this file" behavior on drop.
+        if (e.type === "drop") {
+          if (e.cancelable) e.preventDefault();
+          return;
+        }
+
+        // For dragover, keep it file-specific so we don't break normal UI interactions.
+        if (!isFileDrag(e)) return;
+
+        if (e.cancelable) e.preventDefault();
+        try { e.dataTransfer.dropEffect = "copy"; } catch (_) {}
+        // IMPORTANT: do NOT stopPropagation — dropZone must still receive the event.
+      }
