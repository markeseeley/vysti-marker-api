+        const canonicalNorm = normalizeThesisDeviceTerm(canonical) || canonical.toLowerCase();
+        if (!termNorm || !canonicalNorm) return;
+
+        if (termNorm.includes(" ")) {
+          phraseTermToCanonical.push({ phrase: termNorm, canonical: canonicalNorm });
+        } else {
+          singleWordTermToCanonical.set(termNorm, canonicalNorm);
+        }
+      });
+
+      return {
+        singleWordTermToCanonical,
+        phraseTermToCanonical,
+        singleWordKeys: Array.from(singleWordTermToCanonical.keys())
