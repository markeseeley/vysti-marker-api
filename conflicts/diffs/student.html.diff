+
+        logDecision("react", reason, {
+          user: email || userId || "unknown",
+          bucket,
+          percentage
+        });
+        window.location.replace(buildTargetUrl());
+      };
+
+      window.__studentReactRollout = {
+        maybeRedirect
+      };
+    })();
